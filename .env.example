# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env ขึ้น git)
# บน Render ให้ตั้งค่าเหล่านี้ในหน้า Environment ของ service

# ===== Cloudinary (ที่เก็บรูป) =====
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret

# ===== บัญชีล็อกอิน (บัญชีเดียว ใช้ร่วมกัน) =====
APP_USERNAME=your_username
# สร้าง hash ด้วยคำสั่ง:  node scripts/hash-password.js "รหัสผ่านของคุณ"
# อย่าเก็บรหัสผ่านจริงเป็น plaintext ที่นี่ ให้เก็บเฉพาะ hash
APP_PASSWORD_HASH=

# ===== ความลับของ session (สุ่มให้ยาวและคาดเดายาก) =====
# สร้างได้ด้วย:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# พอร์ต (ไม่ตั้งก็ได้ ค่าเริ่มต้นคือ 3000)
PORT=3000
